{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm db:generate",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.10.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./seed-categories": "./src/seed-categories.ts"
  }
}

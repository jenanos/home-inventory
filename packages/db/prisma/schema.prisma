generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  householdMembers HouseholdMember[]
  assignedItems    ShoppingItem[]    @relation("AssignedItems")
  createdLinks     ShareLink[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ──────────────────────────────────────────────────

enum Role {
  OWNER
  MEMBER
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Phase {
  BEFORE_MOVE
  FIRST_WEEK
  CAN_WAIT
  NO_RUSH
}

enum ItemStatus {
  PENDING
  PURCHASED
  SKIPPED
}

model Household {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())

  members    HouseholdMember[]
  lists      ShoppingList[]
  categories Category[]
}

model HouseholdMember {
  userId      String @db.Uuid
  householdId String @db.Uuid
  role        Role   @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@id([userId, householdId])
}

model ShoppingList {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  householdId String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household  Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items      ShoppingItem[]
  shareLinks ShareLink[]
}

model ShoppingItem {
  id             String     @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  categoryId     String?    @db.Uuid
  priority       Priority   @default(MEDIUM)
  phase          Phase?
  dueDate        DateTime?
  estimatedPrice Decimal?   @db.Decimal(10, 2)
  url            String?
  storeName      String?
  assignedToId   String?    @db.Uuid
  status         ItemStatus @default(PENDING)
  purchasedAt    DateTime?
  listId         String     @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assignedTo User?        @relation("AssignedItems", fields: [assignedToId], references: [id], onDelete: SetNull)
  list       ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  icon        String?
  color       String?
  householdId String  @db.Uuid
  isDefault   Boolean @default(false)

  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingItem[]

  @@unique([name, householdId])
}

model ShareLink {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  listId    String    @db.Uuid
  createdBy String    @db.Uuid
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  list    ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

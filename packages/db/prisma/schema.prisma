generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ──────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  householdMembers HouseholdMember[]
  assignedItems    ShoppingItem[]    @relation("AssignedItems")
  createdLinks     ShareLink[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ──────────────────────────────────────────────────

enum Role {
  OWNER
  MEMBER
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum Phase {
  BEFORE_MOVE
  FIRST_WEEK
  CAN_WAIT
  NO_RUSH
}

enum ItemStatus {
  PENDING
  PURCHASED
  SKIPPED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

model Household {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())

  members          HouseholdMember[]
  lists            ShoppingList[]
  categories       Category[]
  maintenanceTasks MaintenanceTask[]
  budget           Budget?
}

model HouseholdMember {
  userId      String @db.Uuid
  householdId String @db.Uuid
  role        Role   @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@id([userId, householdId])
}

model ShoppingList {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  householdId String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household  Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items      ShoppingItem[]
  shareLinks ShareLink[]
}

model ShoppingItem {
  id             String     @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  categoryId     String?    @db.Uuid
  priority       Priority   @default(MEDIUM)
  phase          Phase?
  dueDate        DateTime?
  estimatedPrice Decimal?   @db.Decimal(10, 2)
  url            String?
  imageUrl       String?
  storeName      String?
  assignedToId   String?    @db.Uuid
  status         ItemStatus @default(PENDING)
  purchasedAt    DateTime?
  listId         String     @db.Uuid
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  category     Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assignedTo   User?                @relation("AssignedItems", fields: [assignedToId], references: [id], onDelete: SetNull)
  list         ShoppingList         @relation(fields: [listId], references: [id], onDelete: Cascade)
  alternatives ProductAlternative[]
}

model ProductAlternative {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  price     Decimal? @db.Decimal(10, 2)
  url       String?
  imageUrl  String?
  storeName String?
  notes     String?
  rank      Int      @default(0)
  itemId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item ShoppingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, rank])
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  icon        String?
  color       String?
  householdId String  @db.Uuid
  isDefault   Boolean @default(false)

  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ShoppingItem[]

  @@unique([name, householdId])
}

model ShareLink {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  listId    String    @db.Uuid
  createdBy String    @db.Uuid
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  list    ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  creator User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

// ─── Maintenance models ─────────────────────────────────────────

model MaintenanceTask {
  id                String     @id @default(uuid()) @db.Uuid
  title             String
  description       String?    @db.Text
  priority          Priority   @default(MEDIUM)
  status            TaskStatus @default(NOT_STARTED)
  estimatedDuration String?
  estimatedPrice    Decimal?   @db.Decimal(10, 2)
  dueDate           DateTime?
  householdId       String     @db.Uuid
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  household       Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  vendors         TaskVendor[]
  progressEntries TaskProgressEntry[]
}

model TaskVendor {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?  @db.Text
  phone          String?
  email          String?
  website        String?
  estimatedPrice Decimal? @db.Decimal(10, 2)
  notes          String?  @db.Text
  isSelected     Boolean  @default(false)
  taskId         String   @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TaskProgressEntry {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  description String?   @db.Text
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  taskId      String    @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task MaintenanceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, sortOrder])
}

// ─── Budget models ──────────────────────────────────────────────

enum BudgetEntryType {
  INCOME
  EXPENSE
  DEDUCTION
}

enum BudgetCategory {
  // Housing costs (Boligkostnader)
  ELECTRICITY
  MUNICIPAL_FEES
  INSURANCE
  HOME_MAINTENANCE

  // Fixed costs (Faste kostnader)
  TRANSPORT
  SUBSCRIPTIONS
  FOOD
  CHILDREN
  PERSONAL
  SAVINGS
  BUFFER
}

model Budget {
  id                  String   @id @default(uuid()) @db.Uuid
  householdId         String   @unique @db.Uuid
  taxDeductionPercent Decimal  @default(22) @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  household Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  members   BudgetMember[]
  loans     BudgetLoan[]
  entries   BudgetEntry[]
}

model BudgetMember {
  id                 String  @id @default(uuid()) @db.Uuid
  budgetId           String  @db.Uuid
  name               String
  grossMonthlyIncome Decimal @db.Decimal(10, 2)
  taxPercent         Decimal @db.Decimal(5, 2)
  sortOrder          Int     @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, sortOrder])
}

model BudgetLoan {
  id               String  @id @default(uuid()) @db.Uuid
  budgetId         String  @db.Uuid
  bankName         String
  loanName         String
  monthlyInterest  Decimal @db.Decimal(10, 2)
  monthlyPrincipal Decimal @db.Decimal(10, 2)
  monthlyFees      Decimal @default(0) @db.Decimal(10, 2)
  sortOrder        Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, sortOrder])
}

model BudgetEntry {
  id            String          @id @default(uuid()) @db.Uuid
  budgetId      String          @db.Uuid
  name          String
  category      BudgetCategory?
  type          BudgetEntryType
  monthlyAmount Decimal         @db.Decimal(10, 2)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, sortOrder])
}
